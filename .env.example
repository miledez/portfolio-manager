# Copy to .env.local and fill in real values. .env* is gitignored — never commit secrets.

# Supabase (URL is public; anon/publishable key is safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://azccsvqcdjqgxcvkvpes.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Server-only secrets — never exposed to the client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
MARKET_DATA_API_KEY=your-finnhub-api-key
CRON_SECRET=generate-a-long-random-string

# Optional: server-side pricing fallback (Anthropic web search)
# ANTHROPIC_API_KEY=your-anthropic-api-key
